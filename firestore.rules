rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Allow read access for both authenticated users and for the login check (includes list/query)
      allow read: if true;
      // Allow users to update their own profile OR another user's balance during a transfer
      allow write: if request.auth != null;
    }
    
    match /transactions/{transactionId} {
      // Allow authenticated users to create transaction records
      allow create: if request.auth != null;
      // Users can only read their own transactions
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
